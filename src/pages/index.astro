---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import ArticleCard from '../components/ArticleCard.astro';

const featuredArticles = [
  {
    title: 'The Ultimate Home Office Setup Guide 2026: Everything You Need',
    excerpt: 'From desk to monitor to lighting — a complete step-by-step guide to building a home office that boosts your productivity and protects your health.',
    href: '/blog/home-office-setup-guide-2026/',
    date: '2026-07-15',
    category: 'Home Office',
    readTime: '12',
  },
  {
    title: 'Ergonomic Chair Buying Guide: How to Choose the Right One for Your Body',
    excerpt: 'Stop back pain. Learn exactly what to look for in an ergonomic chair — lumbar support, seat depth, armrests, and the best models at every budget.',
    href: '/blog/ergonomic-chair-buying-guide/',
    date: '2026-07-14',
    category: 'Ergonomics',
    readTime: '10',
  },
  {
    title: 'Monitor Setup Guide: Single vs Dual vs Ultrawide for Productivity',
    excerpt: 'The science of screen real estate. Compare single, dual, and ultrawide monitor setups and find the best configuration for your workflow.',
    href: '/blog/monitor-setup-guide/',
    date: '2026-07-13',
    category: 'Tech & Gear',
    readTime: '9',
  },
];
---

<BaseLayout
  title="Build Your Perfect Home Office — Free Guides & Tools"
  description="Practical guides, gear reviews, and free interactive tools to help you build a productive, comfortable home office. Everything you need for remote work success."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-900 via-primary-800 to-primary-950">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxnIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wMyI+PGNpcmNsZSBjeD0iMzAiIGN5PSIzMCIgcj0iMiIvPjwvZz48L2c+PC9zdmc+')] opacity-30"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center rounded-full bg-white/10 px-4 py-1.5 mb-6">
          <span class="text-sm font-medium text-white/90">🏠 Free tools &amp; guides for remote workers</span>
        </div>
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Your home office, <span class="text-accent-400">designed right</span>
        </h1>
        <p class="mt-6 text-lg leading-8 text-white/80 max-w-2xl">
          Working from home should not mean working from your couch. We help you build a comfortable, productive home office — with free tools, honest gear reviews, and practical setup guides. No fluff, just what works.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/tools/home-office-planner/" class="inline-flex items-center justify-center rounded-lg border-2 border-white px-8 py-4 text-base font-bold text-white shadow-lg hover:bg-white hover:text-primary-700 transition-all duration-200 no-underline">
            Plan Your Home Office &rarr;
          </a>
          <a href="/blog/home-office-setup-guide-2026/" class="inline-flex items-center justify-center rounded-lg border-2 border-white/70 px-8 py-4 text-base font-semibold text-white hover:bg-white/15 hover:border-white transition-colors no-underline">
            Read the Setup Guide
          </a>
        </div>
      </div>
      <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="rounded-xl bg-white/10 backdrop-blur-sm p-5 border border-white/10">
          <div class="text-2xl font-bold text-white">62%</div>
          <p class="mt-1 text-sm text-white/70">of employed Americans worked remotely at least part-time in 2026</p>
        </div>
        <div class="rounded-xl bg-white/10 backdrop-blur-sm p-5 border border-white/10">
          <div class="text-2xl font-bold text-white">47%</div>
          <p class="mt-1 text-sm text-white/70">of remote workers report improved productivity with a proper home office setup</p>
        </div>
        <div class="rounded-xl bg-white/10 backdrop-blur-sm p-5 border border-white/10">
          <div class="text-2xl font-bold text-white">$11,000</div>
          <p class="mt-1 text-sm text-white/70">average annual savings for full-time remote workers (commute, food, wardrobe)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="section-title">Free Tools for Remote Workers</h2>
        <p class="section-subtitle max-w-2xl mx-auto">No sign-up. No email collection. Just practical tools that actually help.</p>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
        <ToolCard title="Home Office Planner" description="Answer a few questions about your space and budget. Get a personalized setup plan with furniture layout and product picks." icon="📐" href="/tools/home-office-planner/" />
        <ToolCard title="Ergonomic Calculator" description="Enter your height and get exact desk, chair, and monitor measurements for a pain-free workday." icon="📏" href="/tools/ergonomic-calculator/" />
        <ToolCard title="Remote Job Finder" description="Find the best remote job platforms for your industry. Compare features, salary ranges, and job types." icon="💼" href="/tools/remote-job-finder/" />
        <ToolCard title="Productivity Scorecard" description="Assess your WFH productivity in 5 minutes. Get a personalized score and actionable tips to improve." icon="📊" href="/tools/productivity-scorecard/" />
        <ToolCard title="Pomodoro Timer" description="A clean focus timer. 25-minute work sessions with breaks. Beat procrastination without an app." icon="🍅" href="/tools/pomodoro-timer/" />
      </div>
    </div>
  </section>

  <!-- Latest Guides -->
  <section class="py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="section-title">Latest Guides</h2>
          <p class="section-subtitle">Honest, in-depth guides. No sponsored fluff.</p>
        </div>
        <a href="/blog/" class="btn-secondary hidden sm:inline-flex no-underline">View All Guides &rarr;</a>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {featuredArticles.map((article) => (<ArticleCard {...article} />))}
      </div>
      <div class="mt-8 text-center sm:hidden">
        <a href="/blog/" class="btn-secondary no-underline">View All Guides &rarr;</a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="section-title">Build Your Home Office in 3 Steps</h2>
        <p class="section-subtitle max-w-2xl mx-auto">You do not need an interior designer. You just need a plan.</p>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-2xl font-bold text-primary-700">1</div>
          <h3 class="mt-5 text-lg font-semibold text-gray-900">Plan Your Space</h3>
          <p class="mt-2 text-sm text-gray-600">Use our free Home Office Planner to design a layout that fits your room, budget, and work style in under 5 minutes.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-2xl font-bold text-primary-700">2</div>
          <h3 class="mt-5 text-lg font-semibold text-gray-900">Pick the Right Gear</h3>
          <p class="mt-2 text-sm text-gray-600">Check our honest buying guides and comparison tools. We cover every budget from $50 to $5,000.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-2xl font-bold text-primary-700">3</div>
          <h3 class="mt-5 text-lg font-semibold text-gray-900">Set It Up Ergonomically</h3>
          <p class="mt-2 text-sm text-gray-600">Use our Ergonomic Calculator to dial in the perfect desk height, chair position, and monitor placement.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary-700">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to build a home office you actually enjoy working in?</h2>
      <p class="mt-3 text-lg text-primary-100">Use our free Home Office Planner and get a personalized setup in 5 minutes.</p>
      <a href="/tools/home-office-planner/" class="mt-8 inline-flex items-center rounded-lg bg-white px-8 py-4 text-base font-semibold text-primary-700 shadow-sm hover:bg-primary-50 transition-colors no-underline">Plan My Home Office &rarr;</a>
    </div>
  </section>
</BaseLayout>
