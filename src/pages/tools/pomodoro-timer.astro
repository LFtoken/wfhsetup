---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PomodoroTimer from '../../components/PomodoroTimer';
---

<BaseLayout
  title="Free Pomodoro Timer — Stay Focused & Beat Procrastination"
  description="A simple, beautiful Pomodoro timer that runs in your browser. 25-minute focus sessions, 5-minute breaks. No sign-up, no ads, no distractions."
>
  <section class="py-16 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">🍅 Pomodoro Timer</h1>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          A clean, distraction-free Pomodoro timer to help you focus. 25 minutes of deep work, then a 5-minute break. Repeat. No account needed — it just works.
        </p>
        <div class="mt-4 flex justify-center gap-6 text-sm text-gray-500">
          <span>🔒 Runs in your browser</span>
          <span>📱 Works on mobile</span>
          <span>💯 Free forever</span>
        </div>
      </div>
      <PomodoroTimer client:load />

      <!-- Download section -->
      <div class="mt-16 mx-auto max-w-2xl">
        <div class="rounded-2xl bg-gray-50 border border-gray-200 p-8">
          <h2 class="text-xl font-bold text-gray-900 text-center">💻 Make It a Desktop Timer</h2>
          <p class="mt-2 text-sm text-gray-600 text-center">
            Download this timer as a standalone file so it stays visible while you work in other apps.
          </p>

          <!-- Step 1 -->
          <div class="mt-8 flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-600 text-white flex items-center justify-center text-sm font-bold">1</div>
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900">Download the file</h3>
              <p class="text-sm text-gray-600 mt-1">Click the button below to save <code class="bg-gray-200 px-1 rounded">pomodoro-timer.html</code> to your computer.</p>
              <a href="/pomodoro-timer.html" download class="mt-3 inline-flex items-center rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary-700 transition-colors no-underline">
                ⬇ Download Timer (3 KB)
              </a>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="mt-6 flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-600 text-white flex items-center justify-center text-sm font-bold">2</div>
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900">Open it as a standalone window</h3>
              <p class="text-sm text-gray-600 mt-1">Pick the method that works for you:</p>
              <div class="mt-3 space-y-3">
                <div class="rounded-lg bg-white border border-gray-200 p-3">
                  <p class="text-sm font-medium text-gray-800">🪟 Method A — App Window (best)</p>
                  <ol class="text-sm text-gray-600 mt-1 space-y-1 list-decimal list-inside">
                    <li>Right-click the downloaded file → <strong>Open with → Google Chrome</strong></li>
                    <li>In Chrome: click the three-dot menu (⋮) → <strong>Cast, Save and Share → Create Shortcut</strong></li>
                    <li>Check <strong>"Open as window"</strong> → Create</li>
                    <li>A clean, borderless timer window appears. It stays in your taskbar like a real app.</li>
                  </ol>
                </div>
                <div class="rounded-lg bg-white border border-gray-200 p-3">
                  <p class="text-sm font-medium text-gray-800">📌 Method B — Always on Top</p>
                  <ol class="text-sm text-gray-600 mt-1 space-y-1 list-decimal list-inside">
                    <li>Open the file in any browser</li>
                    <li>Resize the window to a small square</li>
                    <li>Install <a href="https://learn.microsoft.com/en-us/windows/powertoys/" class="text-primary-600 underline" target="_blank">Microsoft PowerToys</a> (free, official Microsoft tool)</li>
                    <li>Select the timer window and press <strong>Win + Ctrl + T</strong> to pin it on top</li>
                  </ol>
                </div>
                <div class="rounded-lg bg-white border border-gray-200 p-3">
                  <p class="text-sm font-medium text-gray-800">📱 Method C — Phone / Tablet</p>
                  <p class="text-sm text-gray-600 mt-1">
                    The online timer works perfectly on mobile. Just open <strong>wfhsetup.com/tools/pomodoro-timer/</strong> on your phone, add it to your home screen, and keep it next to your keyboard.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="mt-6 flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-600 text-white flex items-center justify-center text-sm font-bold">3</div>
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900">Start your first focus session</h3>
              <p class="text-sm text-gray-600 mt-1">
                Pick one task. Start the 25-minute timer. Work until it rings. Take a 5-minute break. Then repeat. After 4 sessions, take a longer 15-minute break. That is the entire Pomodoro system — simple, but surprisingly effective.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
