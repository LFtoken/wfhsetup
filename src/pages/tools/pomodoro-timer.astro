---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PomodoroTimer from '../../components/PomodoroTimer';
---

<BaseLayout
  title="Free Pomodoro Timer — Stay Focused & Beat Procrastination"
  description="A simple, beautiful Pomodoro timer that runs in your browser. 25-minute focus sessions, 5-minute breaks. No sign-up, no ads, no distractions."
>
  <section class="py-16 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">🍅 Pomodoro Timer</h1>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          A clean, distraction-free Pomodoro timer to help you focus. 25 minutes of deep work, then a 5-minute break. Repeat. No account needed — it just works.
        </p>
        <div class="mt-4 flex justify-center gap-6 text-sm text-gray-500">
          <span>🔒 Runs in your browser</span>
          <span>📱 Works on mobile</span>
          <span>💯 Free forever</span>
        </div>
      </div>
      <PomodoroTimer client:load />

      <!-- Download section -->
      <div class="mt-16 mx-auto max-w-md">
        <div class="rounded-2xl bg-gray-50 border border-gray-200 p-6 text-center">
          <h2 class="text-lg font-semibold text-gray-900">💻 Download Desktop Mini Timer</h2>
          <p class="mt-2 text-sm text-gray-600">
            A tiny floating Pomodoro timer that sits on top of your other windows. Download the file, double-click to open, and pin it to your screen.
          </p>
          <div class="mt-4 flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/pomodoro-timer.html" download class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-3 text-sm font-semibold text-white hover:bg-primary-700 transition-colors no-underline">
              ⬇ Download Mini Timer
            </a>
            <span class="text-xs text-gray-400 self-center">
              Single HTML file &middot; 3 KB &middot; No install
            </span>
          </div>
          <p class="mt-4 text-xs text-gray-400">
            <strong>How to use:</strong> Open the downloaded file in your browser, then use <a href="https://support.google.com/chrome/answer/95472" class="underline" target="_blank">Picture-in-Picture</a> or resize the window to a small square and keep it in the corner of your screen. Works offline.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
