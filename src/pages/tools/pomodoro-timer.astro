---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PomodoroTimer from '../../components/PomodoroTimer';
---

<BaseLayout
  title="Free Pomodoro Timer — Stay Focused & Beat Procrastination"
  description="A simple, beautiful Pomodoro timer that runs in your browser. 25-minute focus sessions, 5-minute breaks. No sign-up, no ads, no distractions."
>
  <section class="py-16 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">🍅 Pomodoro Timer</h1>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          A clean, distraction-free Pomodoro timer to help you focus. 25 minutes of deep work, then a 5-minute break. Repeat. No account needed — it just works.
        </p>
        <div class="mt-4 flex justify-center gap-6 text-sm text-gray-500">
          <span>🔒 Runs in your browser</span>
          <span>📱 Works on mobile</span>
          <span>💯 Free forever</span>
        </div>
      </div>
      <PomodoroTimer client:load />

      <!-- Download section -->
      <div class="mt-16 mx-auto max-w-md">
        <div class="rounded-2xl bg-gray-50 border border-gray-200 p-6 text-center">
          <h2 class="text-lg font-semibold text-gray-900">💻 Download Desktop Timer</h2>
          <p class="mt-2 text-sm text-gray-600">
            A tiny floating Pomodoro timer that stays on top of other windows. No install — just double-click to run.
          </p>
          <div class="mt-4 flex flex-col gap-3 items-center">
            <a href="/pomodoro-app/PomodoroTimer.exe" class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-3 text-sm font-semibold text-white hover:bg-primary-700 transition-colors no-underline w-full sm:w-auto">
              ⬇ Download for Windows (.exe)
            </a>
            <span class="text-xs text-gray-400">
              192 KB &middot; Always on top &middot; Native Windows app
            </span>
            <div class="border-t border-gray-200 w-full my-2"></div>
            <a href="/pomodoro-timer.html" class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-6 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors no-underline w-full sm:w-auto">
              ⬇ Download for Mac/Linux (.html)
            </a>
            <span class="text-xs text-gray-400">
              3 KB &middot; Works in any browser &middot; Offline
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
