    date: '2026-07-15',
    category: 'Tech & Gear',
    readTime: '10',
  },
  {
    title: 'The Ultimate Home Office Setup Guide 2026: Everything You Need',
    excerpt: 'From desk to monitor to lighting — a complete step-by-step guide to building a home office that boosts your productivity and protects your health.',
    href: '/blog/home-office-setup-guide-2026/',
    date: '2026-07-15',
    category: 'Home Office',
    readTime: '12',
  },
  {
    title: 'Best Home Office Desks 2026: Budget to Premium (With Real User Reviews)',
    excerpt: 'Compare the best desks for home offices across every price tier. From compact $100 desks to premium standing desks, find the right one for your space and budget.',
    href: '/blog/best-home-office-desks-2026/',
