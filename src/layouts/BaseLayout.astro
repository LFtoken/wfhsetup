---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  canonicalURL,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | RemoteWorkHQ</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="RemoteWorkHQ" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    {canonicalURL ? (
      <link rel="canonical" href={canonicalURL} />
    ) : (
      <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    )}

    <!-- Schema: WebSite -->
    <script type="application/ld+json" set:html={`{
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "RemoteWorkHQ",
      "url": "${Astro.site}",
      "description": "Practical guides, gear reviews, and free tools to help you build a productive and comfortable home office. Everything you need for remote work success.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "${Astro.site}/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Google Analytics (consent-based) -->
    <script>
      // Only load GA if user has given cookie consent
      (function() {
        const consent = localStorage.getItem('cookieConsent');
        if (consent === 'accepted') {
          const gaScript = document.createElement('script');
          gaScript.async = true;
          gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-WE24ZRCD9Z';
          document.head.appendChild(gaScript);
          gaScript.onload = function() {
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-WE24ZRCD9Z');
          };
        }
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="sticky top-0 z-50 border-b border-gray-100 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Main navigation">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-primary-700 no-underline">
          <span class="text-2xl" role="img" aria-label="home office">🏠</span>
          <span>RemoteWorkHQ</span>
        </a>
        <div class="hidden items-center gap-8 sm:flex">
          <a href="/tools/" class="text-sm font-medium text-gray-600 hover:text-primary-700 transition-colors">Tools</a>
          <a href="/blog/" class="text-sm font-medium text-gray-600 hover:text-primary-700 transition-colors">Guides</a>
          <a href="/about/" class="text-sm font-medium text-gray-600 hover:text-primary-700 transition-colors">About</a>
          <a href="/contact/" class="text-sm font-medium text-gray-600 hover:text-primary-700 transition-colors">Contact</a>
        </div>
        <button class="sm:hidden rounded-lg p-2 text-gray-600 hover:bg-gray-100" id="mobile-menu-btn" aria-label="Open menu">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        </button>
      </nav>
      <!-- Mobile menu -->
      <div class="hidden sm:hidden border-t border-gray-100 bg-white px-4 py-3" id="mobile-menu">
        <div class="flex flex-col gap-3">
          <a href="/tools/" class="text-sm font-medium text-gray-600 hover:text-primary-700">Tools</a>
          <a href="/blog/" class="text-sm font-medium text-gray-600 hover:text-primary-700">Guides</a>
          <a href="/about/" class="text-sm font-medium text-gray-600 hover:text-primary-700">About</a>
          <a href="/contact/" class="text-sm font-medium text-gray-600 hover:text-primary-700">Contact</a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-gray-100 bg-gray-50">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
          <div>
            <h3 class="text-sm font-semibold text-gray-900">RemoteWorkHQ</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Practical guides, gear reviews, and free tools to help you build a productive home office and thrive in remote work.
            </p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900">Resources</h3>
            <ul class="mt-3 space-y-2">
              <li><a href="/tools/" class="text-sm text-gray-600 hover:text-primary-700">Free Tools</a></li>
              <li><a href="/blog/" class="text-sm text-gray-600 hover:text-primary-700">Guides & Articles</a></li>
              <li><a href="/tools/home-office-planner/" class="text-sm text-gray-600 hover:text-primary-700">Home Office Planner</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900">Company</h3>
            <ul class="mt-3 space-y-2">
              <li><a href="/about/" class="text-sm text-gray-600 hover:text-primary-700">About</a></li>
              <li><a href="/contact/" class="text-sm text-gray-600 hover:text-primary-700">Contact</a></li>
              <li><a href="/privacy/" class="text-sm text-gray-600 hover:text-primary-700">Privacy Policy</a></li>
              <li><a href="/terms/" class="text-sm text-gray-600 hover:text-primary-700">Terms of Service</a></li>
              <li><a href="#" id="cookie-settings-link" class="text-sm text-gray-600 hover:text-primary-700">Cookie Settings</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-10 border-t border-gray-200 pt-6">
          <p class="text-xs text-gray-500">&copy; {new Date().getFullYear()} RemoteWorkHQ. All rights reserved. This site provides general information and does not constitute professional advice.</p>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>

    <!-- Cookie Consent Banner -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[100] hidden">
      <div class="mx-auto max-w-7xl px-3 py-3 sm:px-6 lg:px-8">
        <div class="relative rounded-2xl border border-gray-200 bg-white p-4 sm:p-6 shadow-2xl">
          <button id="cookie-close" class="absolute top-3 right-3 text-gray-400 hover:text-gray-600 transition-colors p-1" aria-label="Close cookie banner">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:pr-8">
            <div class="max-w-2xl">
              <h3 class="text-sm font-semibold text-gray-900">This website uses cookies</h3>
              <p class="mt-1 text-xs sm:text-sm text-gray-600">
                We use cookies for analytics and ads. <a href="/privacy/" class="text-primary-600 underline">Learn more</a>
              </p>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <button id="cookie-reject" class="rounded-lg border border-gray-300 px-3 py-2 text-xs sm:text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors min-h-[44px]">
                Essential Only
              </button>
              <button id="cookie-accept" class="rounded-lg bg-primary-600 px-4 py-2 text-xs sm:text-sm font-semibold text-white hover:bg-primary-700 transition-colors min-h-[44px]">
                Accept All
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      (function() {
        const banner = document.getElementById('cookie-banner');
        const acceptBtn = document.getElementById('cookie-accept');
        const rejectBtn = document.getElementById('cookie-reject');
        const closeBtn = document.getElementById('cookie-close');
        const body = document.body;

        function showBanner() {
          banner.classList.remove('hidden');
          body.style.paddingBottom = banner.offsetHeight + 'px';
        }

        function hideBanner() {
          banner.classList.add('hidden');
          body.style.paddingBottom = '0px';
        }

        // Show banner if no consent stored
        if (!localStorage.getItem('cookieConsent')) {
          showBanner();
        }

        function acceptCookies() {
          localStorage.setItem('cookieConsent', 'accepted');
          hideBanner();
          window.location.reload();
        }

        function rejectCookies() {
          localStorage.setItem('cookieConsent', 'rejected');
          hideBanner();
        }

        acceptBtn?.addEventListener('click', acceptCookies);
        rejectBtn?.addEventListener('click', rejectCookies);
        closeBtn?.addEventListener('click', rejectCookies);

        // Cookie settings link in footer — re-opens the banner
        const settingsLink = document.getElementById('cookie-settings-link');
        settingsLink?.addEventListener('click', (e) => {
          e.preventDefault();
          showBanner();
        });
      })();
    </script>
  </body>
</html>
